<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cadena Hexadecimal Original:" />

    <EditText
        android:id="@+id/etHexInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: 4C000000B3FFFFFF4C00000000FF00FF"
        android:inputType="textNoSuggestions" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Unidades reales a sumar:" />

    <EditText
        android:id="@+id/etUnitsInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: 20"
        android:inputType="number" />

    <Button
        android:id="@+id/btnCalculate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="CALCULAR" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Resultado (Cadena calculada):"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="..."
        android:textSize="18sp"
        android:textIsSelectable="true" />

</LinearLayout>